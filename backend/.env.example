# ──────────────────────────────────────────────────────────────────────────────
# LLM Provider
# Set to "openai" to use OpenAI API, or "ollama" to use a local Ollama instance
# ──────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai

# OpenAI API key (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Ollama settings (required when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ──────────────────────────────────────────────────────────────────────────────
# Database
# SQLite file path (relative to backend/ directory)
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/skillbridge.db

# ──────────────────────────────────────────────────────────────────────────────
# File uploads
# ──────────────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ──────────────────────────────────────────────────────────────────────────────
# CORS — comma-separated list of allowed origins
# ──────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
